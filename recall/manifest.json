{
  "manifest_version": 3,
  "name": "Recall",
  "version": "1.0.0",
  "description": "Fuzzy-search your browser history by what you actually remember reading, not just URLs.",
  "permissions": [
    "storage",
    "webNavigation",
    "scripting",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon.png",
      "32": "icons/icon.png",
      "48": "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; connect-src 'none';"
  },
  "omnibox": {
    "keyword": "rc"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  }
}
